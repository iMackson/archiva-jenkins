# Environment variables for Jenkins and Archiva
# Copy this file to .env and customize values

# Jenkins Configuration
JENKINS_JAVA_OPTS=-Djenkins.install.runSetupWizard=false -Xmx2g -Xms1g
JENKINS_ADMIN_PASSWORD=change_this_password
JENKINS_ADMIN_USER=admin

# Archiva Configuration
ARCHIVA_JAVA_OPTS=-Xms512m -Xmx1024m

# SMTP Configuration (uncomment and configure if needed)
# SMTP_HOST=your_smtp_server
# SMTP_PORT=587
# SMTP_SSL=false
# SMTP_TLS=true
# SMTP_USER=your_smtp_user
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=jenkins@yourdomain.com

# Timezone
TZ=UTC